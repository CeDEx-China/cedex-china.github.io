// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/jekyll
{
	"name": "Jekyll",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/jekyll:2-bullseye",

	// Forward Jekyll's default port and livereload WebSocket port.
	"forwardPorts": [4000, 35729],

	// Install dependencies once when the container is first created.
	"postCreateCommand": "bundle install",

	// Start Jekyll with livereload every time the container starts.
	// --force_polling is required on Windows/Docker because filesystem change events
	// from the Windows host are not propagated into the container.
	"postStartCommand": "bundle exec jekyll serve --livereload --host 0.0.0.0 --force_polling"

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
