<style>
  /* Always reserve scrollbar gutter space to prevent layout shift on page transitions */
  html {
    overflow-y: scroll; /* fallback for older browsers */
    scrollbar-gutter: stable; /* modern: reserves space without forcing visible track */
  }

  /* ── Typography ──────────────────────────────────────────────────────────
     Inter for UI/body (optimised screen legibility), Georgia for long prose.
     Font stack follows system-ui best practice with Inter as first web font.
  ── */
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');

  body {
    font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
                 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 1rem;           /* 16px base */
    font-weight: 400;          /* Regular — Inter 400 is readable at 16px+ */
    line-height: 1.7;          /* comfortable reading rhythm */
    font-synthesis: none;      /* prevent browser from faking bold/italic */
    font-feature-settings: 'kern' 1, 'liga' 1;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }

  /* Headings: SemiBold with tight tracking */
  body h1, body h2, body h3, body h4, body h5, body h6 {
    line-height: 1.25;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  /* Nav links: Medium weight for UI clarity */
  #navbar .nav-link,
  #navbar .navbar-brand {
    font-weight: 500;
  }

  /* Tab labels: Medium */
  .nav-tabs .nav-link {
    font-weight: 500;
  }

  /* ── Tables ──────────────────────────────────────────────────────────────
     Reduce table font to 0.85rem (≈13.6px) for data-dense views while
     keeping body copy at 1rem.
  ── */
  table, .table {
    font-size: 0.85rem;
    line-height: 1.5;
  }
  table th, .table th {
    font-weight: 600;
  }
  table td, .table td {
    font-weight: 400;
  }

  body.sticky-bottom-footer {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
  body.sticky-bottom-footer > [role="main"] {
    flex: 1 0 auto;
  }
</style>

<header>
  <!-- Nav Bar -->
  <nav id="navbar" class="navbar navbar-light navbar-expand-sm {% if site.navbar_fixed %}fixed-top{% else %}sticky-top{% endif %}" role="navigation">
    <div class="container">
      <a class="navbar-brand title " href="{{ site.baseurl }}/">
        {% if site.title == 'blank' %}
          {% if site.first_name %}
            <span class="font-weight-bold">
              {{- site.first_name -}}
            </span>
          {% endif %}
          {% if site.middle_name %}
            {{- site.middle_name -}}
          {% endif %}
          {% if site.last_name %}
            {{- site.last_name -}}
          {% endif %}
        {% else %}
          {{- site.title -}}
        {% endif %}
      </a>
      <!-- Navbar Toggle -->
      <button
        class="navbar-toggler collapsed ml-auto"
        type="button"
        data-toggle="collapse"
        data-target="#navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar top-bar"></span>
        <span class="icon-bar middle-bar"></span>
        <span class="icon-bar bottom-bar"></span>
      </button>

      <div class="collapse navbar-collapse text-right" id="navbarNav">
        <ul class="navbar-nav ml-auto flex-nowrap">
          {% assign about_title = 'Home' %}
          {% for p in site.html_pages %}
            {% if p.permalink == '/' %} {% assign about_title = p.title %} {% endif %}
          {% endfor %}

          <!-- About -->
          <li class="nav-item {% if page.permalink == '/' %}active{% endif %}">
            <a class="nav-link" href="{{ '/' | relative_url }}">
              {{- about_title }}
              {% if page.permalink == '/' %}
                <span class="sr-only">(current)</span>
              {% endif %}
            </a>
          </li>

          <!-- Other pages -->
          {% assign sorted_pages = site.html_pages | sort: 'nav_order' %}
          {% for p in sorted_pages %}
            {% if p.nav and p.autogen == null and p.permalink != '/' %}
              {% if p.dropdown %}
                {% assign has_active_child = false %}
                {% for child in p.children %}
                  {% if page.title == child.title %}
                    {% assign has_active_child = true %}
                  {% endif %}
                {% endfor %}
                <li class="nav-item dropdown {% if page.title == p.title or has_active_child %}active{% endif %}">
                  <a
                    class="nav-link dropdown-toggle"
                    href="#"
                    id="navbarDropdown"
                    role="button"
                    data-toggle="dropdown"
                    aria-haspopup="true"
                    aria-expanded="false"
                  >
                    {{- p.title }}
                    {% if page.title == p.title or has_active_child %}
                      <span class="sr-only">(current)</span>
                    {% endif %}
                  </a>
                  <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
                    {% for child in p.children %}
                      {% if child.title == 'divider' %}
                        <div class="dropdown-divider"></div>
                      {% else %}
                        <a
                          class="dropdown-item {% if page.title == child.title %}active{% endif %}"
                          href="{% if child.permalink contains '://' %}{{ child.permalink }}{% else %}{{ child.permalink | relative_url }}{% endif %}"
                        >
                          {{- child.title -}}
                        </a>
                      {% endif %}
                    {% endfor %}
                  </div>
                </li>
              {% else %}
                {% assign parent_link = p.permalink | remove: 'index.html' %}
                <li class="nav-item {% if page.url contains parent_link %}active{% endif %}">
                  {%- if p.nav_url -%}
                    {%- assign url = p.nav_url -%}
                  {%- elsif p.permalink contains '://' -%}
                    {%- assign url = p.permalink -%}
                  {%- elsif p.permalink contains '/blog/' -%}
                    {%- assign url = '/blog/' -%}
                  {%- else -%}
                    {%- assign url = p.url -%}
                  {%- endif %}
                  <a class="nav-link" {% if url contains '://' %}target="_blank" rel="noopener noreferrer"{% endif %} href="{% if url contains '://' %}{{ url }}{% else %}{{ url | relative_url }}{% endif %}">
                    {{- p.title }}
                    {% if page.url contains p.url %}
                      <span class="sr-only">(current)</span>
                    {% endif %}
                  </a>
                </li>
              {% endif %}
            {% endif %}
          {% endfor %}
          {% if site.search_enabled %}
            <!-- Search -->
            <li class="nav-item">
              <button id="search-toggle" title="Search" onclick="openSearchModal()">
                <span class="nav-link">ctrl k <i class="fa-solid fa-magnifying-glass"></i></span>
              </button>
            </li>
          {% endif %}
          {% if site.enable_darkmode %}
            <!-- Toogle theme mode -->
            <li class="toggle-container">
              <button id="light-toggle" title="Change theme">
                <i class="fa-half-sun-moon" id="light-toggle-system"></i>
                <i class="fa-solid fa-moon" id="light-toggle-dark"></i>
                <i class="fa-solid fa-sun" id="light-toggle-light"></i>
              </button>
            </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>
  {% if site.enable_progressbar %}
    <!-- Scrolling Progress Bar -->
    <progress id="progress" value="0">
      <div class="progress-container">
        <span class="progress-bar"></span>
      </div>
    </progress>
  {% endif %}
</header>
